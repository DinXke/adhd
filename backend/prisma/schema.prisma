generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────

enum Role {
  child
  parent
  caregiver
  admin
}

enum ChannelType {
  general
  therapy
  school
  medical
}

enum DossierCategory {
  report
  plan
  medication
  note
  progress
}

enum TokenSourceType {
  activity
  task
  task_step
  exercise
  exercise_session
  emotion_checkin
  morning_routine
  bedtime_routine
  streak
  manual
}

enum TransactionType {
  earned
  redeemed
  manual
}

enum ExerciseType {
  multiple_choice
  drag_drop
  fill_in
  memory
  number_line
  balance_scale
  clock_match
  pizza_fraction
  step_builder
  estimation_race
  shop
}

enum Subject {
  wiskunde
  taal
  spelling
  lezen
  wereldorientatie
}

enum EmotionLevel {
  great
  good
  okay
  sad
  angry
}

// ── Users & Auth ──────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  name        String
  email       String?  @unique
  pin         String?  // Argon2id hash, alleen voor kind
  password    String?  // Argon2id hash, voor ouder/hulpverlener
  role        Role
  avatarUrl   String?
  avatarId    String?  // ID van gekozen avatar (bv. 'meisje-1')
  gender      String?  // 'jongen', 'meisje', 'neutraal'
  dateOfBirth DateTime? // Voor leeftijdsgebaseerde oefeningen
  isActive    Boolean  @default(true)
  totpSecret  String?  // Encrypted, voor TOTP 2FA

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Auth relaties
  refreshTokens  RefreshToken[]
  invitesSent    CaregiverInvite[] @relation("InvitedBy")
  invitesReceived CaregiverInvite[] @relation("InvitedUser")

  // Toegang
  caregiverAccess CaregiverAccess[] @relation("CaregiverUser")
  childrenAccess  CaregiverAccess[] @relation("ChildUser")

  // Ouder-kind relaties
  myChildren  ParentChild[] @relation("ParentChildren")
  myParents   ParentChild[] @relation("ChildParents")

  // Kind-data
  schedules      Schedule[]
  tasks          Task[]       @relation("ChildTasks")
  emotionLogs    EmotionLog[]
  tokenTransactions TokenTransaction[]
  exerciseSessions  ExerciseSession[]

  // Communicatie
  messagesSent   Message[]    @relation("MessageAuthor")
  channelMembers ChannelMember[]
  messageReads   MessageRead[]

  // Dossier
  dossierEntries DossierEntry[] @relation("DossierAuthor")
  dossierAccess  DossierEntry[] @relation("DossierVisibility")

  // Ouder-data
  tasksCreated       Task[]        @relation("ParentCreatedTasks")
  tokenConfigsOwned  TokenConfig[] @relation("TokenConfigChild")
  tokenConfigsCreated TokenConfig[] @relation("TokenConfigCreator")
  rewards            Reward[]
  auditLogs          AuditLog[]

  // TRMNL
  trmnlDevice    TrmnlDevice?

  // Fase 8
  independenceTasks        IndependenceTask[]       @relation("IndependenceCreator")
  independenceCompletions  IndependenceCompletion[] @relation("IndependenceChild")
  socialScripts            SocialScript[]
  pushSubscriptions        PushSubscription[]
  moneyTransactions        MoneyTransaction[]       @relation("MoneyChild")
  moneySavingGoals         MoneySavingGoal[]        @relation("MoneySavingGoalChild")
  recipes                  Recipe[]                 @relation("RecipeCreator")
  appointmentsAsChild      Appointment[]            @relation("AppointmentChild")
  appointmentsCreated      Appointment[]            @relation("AppointmentCreator")
  vacationPeriods          VacationPeriod[]         @relation("VacationChild")
  childLists               ChildList[]              @relation("ChildLists")

  @@map("users")
}

model ParentChild {
  id        String  @id @default(cuid())
  parentId  String
  parent    User    @relation("ParentChildren", fields: [parentId], references: [id], onDelete: Cascade)
  childId   String
  child     User    @relation("ChildParents", fields: [childId], references: [id], onDelete: Cascade)
  isPrimary Boolean @default(false)
  createdAt DateTime @default(now())

  @@unique([parentId, childId])
  @@map("parent_children")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique // SHA-256 hash van het echte token
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  userAgent String?
  ipAddress String?

  @@map("refresh_tokens")
}

model CaregiverInvite {
  id          String    @id @default(cuid())
  token       String    @unique // SHA-256 hash
  email       String
  role        Role      @default(caregiver)
  childId     String
  invitedById String
  invitedBy   User      @relation("InvitedBy", fields: [invitedById], references: [id])
  invitedUser User?     @relation("InvitedUser", fields: [invitedUserId], references: [id])
  invitedUserId String? @unique
  expiresAt   DateTime
  usedAt      DateTime?
  modules     String[]  @default([])
  createdAt   DateTime  @default(now())

  @@map("caregiver_invites")
}

model CaregiverAccess {
  id          String   @id @default(cuid())
  userId      String   // hulpverlener
  user        User     @relation("CaregiverUser", fields: [userId], references: [id], onDelete: Cascade)
  childId     String
  child       User     @relation("ChildUser", fields: [childId], references: [id], onDelete: Cascade)
  modules     String[] // ["communication", "dossier", "exercises", "progress"]
  invitedBy   String
  invitedAt   DateTime @default(now())
  expiresAt   DateTime?
  isActive    Boolean  @default(true)

  @@unique([userId, childId])
  @@map("caregiver_access")
}

// ── Dagstructuur & Taken ──────────────────────────────────────

model Schedule {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayOfWeek  Int      // 0=zondag..6=zaterdag, 7=vakantie-maandag, 8=vakantie-dinsdag, etc.
  label      String?  // "Vakantie maandag", null = normaal
  activities Activity[]
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  vacationPeriods VacationPeriod[]

  @@unique([userId, dayOfWeek])
  @@map("schedules")
}

model Activity {
  id              String   @id @default(cuid())
  scheduleId      String
  schedule        Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  title           String
  icon            String   // naam van SVG icon of emoji
  startTime       String   // "08:15" formaat
  durationMinutes Int
  color           String   @default("#7BAFA3")
  notifyBefore    Int[]    @default([5, 1]) // minuten voor notificatie
  sortOrder       Int      @default(0)
  steps           ActivityStep[]

  @@map("activities")
}

model ActivityStep {
  id         String   @id @default(cuid())
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  title      String
  icon       String?
  sortOrder  Int      @default(0)

  @@map("activity_steps")
}

model Task {
  id          String   @id @default(cuid())
  childId     String
  child       User     @relation("ChildTasks", fields: [childId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation("ParentCreatedTasks", fields: [createdById], references: [id])
  title       String
  description String?
  icon        String?
  durationMinutes Int?
  scheduledFor DateTime?
  completedAt  DateTime?
  sortOrder   Int      @default(0)
  steps       TaskStep[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tasks")
}

model TaskStep {
  id          String    @id @default(cuid())
  taskId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title       String
  icon        String?
  sortOrder   Int       @default(0)
  completedAt DateTime?

  @@map("task_steps")
}

// ── Beloningssysteem ─────────────────────────────────────────

model TokenConfig {
  id                    String          @id @default(cuid())
  childId               String
  child                 User            @relation("TokenConfigChild", fields: [childId], references: [id], onDelete: Cascade)
  sourceType            TokenSourceType
  sourceId              String?         // specifieke activiteit/taak ID
  enabled               Boolean         @default(true)
  tokensPerCompletion   Int             @default(1)
  bonusTokens           Int?
  createdById           String
  createdBy             User            @relation("TokenConfigCreator", fields: [createdById], references: [id])
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  // Geen unique constraint op sourceId omdat null-waarden niet vergelijkbaar zijn in PostgreSQL
  @@index([childId, sourceType])
  @@map("token_configs")
}

model Reward {
  id               String    @id @default(cuid())
  childId          String
  child            User      @relation(fields: [childId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  imageUrl         String?
  costTokens       Int
  isAvailable      Boolean   @default(true)
  requiresApproval Boolean   @default(true)
  category         String?
  expiresAt        DateTime?
  sortOrder        Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  transactions     TokenTransaction[]

  @@map("rewards")
}

model TokenTransaction {
  id         String          @id @default(cuid())
  childId    String
  child      User            @relation(fields: [childId], references: [id], onDelete: Cascade)
  amount     Int             // positief bij verdienen, negatief bij inwisselen
  type       TransactionType
  sourceType String
  sourceId   String?
  rewardId   String?
  reward     Reward?         @relation(fields: [rewardId], references: [id])
  note       String?
  grantedById String?
  createdAt  DateTime        @default(now())

  @@map("token_transactions")
}

// ── Schooloefeningen ─────────────────────────────────────────

model Exercise {
  id           String       @id @default(cuid())
  subject      Subject
  type         ExerciseType
  difficulty   Int          @default(1) // 1-5
  title        String?
  questionJson Json         // volledig oefening-schema
  tags         String[]
  isAiGenerated Boolean     @default(false)
  isApproved    Boolean     @default(true)
  generatedBy   String?     // "claude-haiku-3-5"
  createdById   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  sessions     ExerciseSessionItem[]

  @@map("exercises")
}

model ExerciseSession {
  id          String   @id @default(cuid())
  childId     String
  child       User     @relation(fields: [childId], references: [id], onDelete: Cascade)
  subject     Subject
  startedAt   DateTime @default(now())
  completedAt DateTime?
  durationSeconds Int?
  items       ExerciseSessionItem[]

  @@map("exercise_sessions")
}

model ExerciseSessionItem {
  id          String          @id @default(cuid())
  sessionId   String
  session     ExerciseSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId  String
  exercise    Exercise        @relation(fields: [exerciseId], references: [id])
  isCorrect   Boolean?
  attempts    Int             @default(0)
  answeredAt  DateTime?
  timeSeconds Int?

  @@map("exercise_session_items")
}

// ── Emotieregulatie ───────────────────────────────────────────

model EmotionLog {
  id        String       @id @default(cuid())
  childId   String
  child     User         @relation(fields: [childId], references: [id], onDelete: Cascade)
  level     EmotionLevel
  note      String?
  createdAt DateTime     @default(now())

  @@map("emotion_logs")
}

// ── Communicatieportaal ───────────────────────────────────────

model Channel {
  id       String      @id @default(cuid())
  name     String
  childId  String
  type     ChannelType @default(general)
  members  ChannelMember[]
  messages Message[]
  createdAt DateTime   @default(now())

  @@map("channels")
}

model ChannelMember {
  id        String  @id @default(cuid())
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@map("channel_members")
}

model Message {
  id                String        @id @default(cuid())
  channelId         String
  channel           Channel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  authorId          String
  author            User          @relation("MessageAuthor", fields: [authorId], references: [id])
  content           String
  isStructuredUpdate Boolean      @default(false)
  templateData      Json?
  attachments       Attachment[]
  reads             MessageRead[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("messages")
}

model MessageRead {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt    DateTime @default(now())

  @@unique([messageId, userId])
  @@map("message_reads")
}

// ── Dossier ───────────────────────────────────────────────────

model DossierEntry {
  id          String          @id @default(cuid())
  childId     String
  category    DossierCategory
  title       String
  content     String
  authorId    String
  author      User            @relation("DossierAuthor", fields: [authorId], references: [id])
  visibility  User[]          @relation("DossierVisibility")
  attachments Attachment[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("dossier_entries")
}

model Attachment {
  id          String        @id @default(cuid())
  filename    String
  mimeType    String
  storageKey  String        // MinIO object key
  sizeBytes   Int
  uploadedById String
  messageId   String?
  message     Message?      @relation(fields: [messageId], references: [id])
  dossierId   String?
  dossierEntry DossierEntry? @relation(fields: [dossierId], references: [id])
  uploadedAt  DateTime      @default(now())

  @@map("attachments")
}

// ── TRMNL E-Paper ────────────────────────────────────────────

model TrmnlDevice {
  id             String   @id @default(cuid())
  childId        String   @unique
  child          User     @relation(fields: [childId], references: [id], onDelete: Cascade)
  userUuid       String   @unique // TRMNL user_uuid
  accessToken    String   // gehashed
  screens        String[] @default(["day_overview", "tokens", "current_task"])
  refreshMinutes Int      @default(15)
  nightModeStart String   @default("21:00")
  nightModeEnd   String   @default("07:00")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@map("trmnl_devices")
}

// ── Levensvaardigheden ────────────────────────────────────────

model IndependenceTask {
  id          String   @id @default(cuid())
  childId     String   // specifiek voor dit kind
  child       User     @relation("IndependenceCreator", fields: [childId], references: [id], onDelete: Cascade)
  title       String
  description String?
  icon        String   @default("✅")
  category    String   @default("thuis") // "thuis", "school", "sociaal", "zelfredzaamheid"
  frequency   String   @default("daily") // "daily", "weekly", "milestone"
  minAge      Int?
  maxAge      Int?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  completions IndependenceCompletion[]
  createdAt   DateTime @default(now())

  @@map("independence_tasks")
}

model IndependenceCompletion {
  id          String           @id @default(cuid())
  taskId      String
  task        IndependenceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  childId     String
  child       User             @relation("IndependenceChild", fields: [childId], references: [id], onDelete: Cascade)
  completedAt DateTime         @default(now())
  note        String?

  @@map("independence_completions")
}

// ── Sociale Scripts ───────────────────────────────────────────

model SocialScript {
  id            String   @id @default(cuid())
  childId       String
  child         User     @relation(fields: [childId], references: [id], onDelete: Cascade)
  title         String
  scenario      String
  category      String   @default("algemeen") // "hulp_vragen", "conflict", "vrienden", "regels", "algemeen"
  choices       Json     // [{text, outcome, isPositive, tip}]
  difficulty    Int      @default(1)
  isAiGenerated Boolean  @default(false)
  playCount     Int      @default(0)
  createdAt     DateTime @default(now())

  @@map("social_scripts")
}

// ── Push Subscriptions ────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}

// ── Geldmodule ───────────────────────────────────────────────

model MoneyTransaction {
  id        String   @id @default(cuid())
  childId   String
  child     User     @relation("MoneyChild", fields: [childId], references: [id], onDelete: Cascade)
  amount    Int      // centen (positief = storten, negatief = uitgeven)
  type      String   // "allowance", "earning", "spending", "saving"
  note      String?
  grantedBy String?  // userId van ouder bij manuele stortingen
  createdAt DateTime @default(now())

  @@map("money_transactions")
}

model MoneySavingGoal {
  id          String   @id @default(cuid())
  childId     String
  child       User     @relation("MoneySavingGoalChild", fields: [childId], references: [id], onDelete: Cascade)
  title       String
  targetAmount Int     // centen
  icon        String   @default("🎯")
  isReached   Boolean  @default(false)
  reachedAt   DateTime?
  createdAt   DateTime @default(now())

  @@map("money_saving_goals")
}

// ── Recepten ──────────────────────────────────────────────────

model Recipe {
  id          String       @id @default(cuid())
  childId     String
  child       User         @relation("RecipeCreator", fields: [childId], references: [id], onDelete: Cascade)
  title       String
  icon        String       @default("🍳")
  description String?
  steps       RecipeStep[]
  duration    Int?         // minuten
  difficulty  Int          @default(1) // 1-3
  isActive    Boolean      @default(true)
  playCount   Int          @default(0)
  createdAt   DateTime     @default(now())

  @@map("recipes")
}

model RecipeStep {
  id          String  @id @default(cuid())
  recipeId    String
  recipe      Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  sortOrder   Int
  title       String
  description String?
  duration    Int?    // seconden
  imageUrl    String?
  tip         String?

  @@map("recipe_steps")
}

// ── Dagelijkse ouder-tip ──────────────────────────────────────

model DailyTip {
  id        String   @id @default(cuid())
  childId   String
  content   String
  date      String   // YYYY-MM-DD
  createdAt DateTime @default(now())

  @@unique([childId, date])
  @@map("daily_tips")
}

// ── Vakantieperiodes ─────────────────────────────────────────

model VacationPeriod {
  id          String   @id @default(cuid())
  childId     String
  child       User     @relation("VacationChild", fields: [childId], references: [id], onDelete: Cascade)
  title       String   // "Kerstvakantie", "Zomervakantie", "Vrije dag"
  startDate   DateTime
  endDate     DateTime
  scheduleId  String?  // optioneel: gebruik dit vakantieschema i.p.v. normaal
  schedule    Schedule? @relation(fields: [scheduleId], references: [id])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("vacation_periods")
}

// ── Afspraken/Kalender ────────────────────────────────────────

model Appointment {
  id              String    @id @default(cuid())
  childId         String
  child           User      @relation("AppointmentChild", fields: [childId], references: [id], onDelete: Cascade)
  createdById     String
  createdBy       User      @relation("AppointmentCreator", fields: [createdById], references: [id])
  title           String
  icon            String    @default("📅")
  color           String    @default("#7BAFA3")
  location        String?
  notes           String?
  startTime       String    // "14:00"
  durationMinutes Int       @default(60)
  isRecurring     Boolean   @default(false)
  dayOfWeek       Int?      // 0=zondag..6=zaterdag (bij recurring)
  date            DateTime? // specifieke datum (bij éénmalig)
  showInChildView Boolean   @default(true)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("appointments")
}

// ── Kind-lijstjes ─────────────────────────────────────────────

model ChildList {
  id        String   @id @default(cuid())
  childId   String
  child     User     @relation("ChildLists", fields: [childId], references: [id], onDelete: Cascade)
  title     String
  icon      String   @default("📝")
  color     String   @default("#7BAFA3")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  items     ChildListItem[]

  @@map("child_lists")
}

model ChildListItem {
  id          String    @id @default(cuid())
  listId      String
  list        ChildList @relation(fields: [listId], references: [id], onDelete: Cascade)
  title       String
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  @@map("child_list_items")
}

// ── Audit Log ─────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String   // "user.login", "task.complete", "reward.redeem", etc.
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}
