# Database
DB_PASS=changeme_in_production

# Auth
JWT_SECRET=changeme_in_production_min32chars

# Web Push (VAPID) — genereer met: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:bjorn@scheepers.one

# MinIO (bestandsopslag)
MINIO_USER=julieapp
MINIO_PASS=changeme_in_production

# Home Assistant (optioneel)
HA_URL=
HA_TOKEN=

# Claude API (optioneel — voor oefening-generatie)
CLAUDE_API_KEY=

# App
APP_URL=https://julie.scheepers.one
APP_PORT=3080
NODE_ENV=production

# Upgrade
GITHUB_REPO=bjornscheepers/julieapp
APP_DIR=/opt/julieapp
