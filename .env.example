# Database
DB_PASS=changeme_in_production

# Auth
JWT_SECRET=changeme_in_production_min32chars

# Web Push (VAPID) — genereer met: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:admin@jouwdomein.be

# MinIO (bestandsopslag)
MINIO_USER=gripapp
MINIO_PASS=changeme_in_production

# Home Assistant (optioneel)
HA_URL=
HA_TOKEN=

# Claude API (optioneel — voor oefening-generatie)
CLAUDE_API_KEY=

# App
APP_URL=https://jouwdomein.be
APP_PORT=3080
NODE_ENV=production

# CORS — komma-gescheiden lijst van toegestane origins
CORS_ORIGINS=https://jouwdomein.be,http://localhost:3080

# Upgrade
GITHUB_REPO=gebruikersnaam/reponaam
APP_DIR=/opt/grip

# Seed-accounts (worden aangemaakt bij eerste start)
SEED_ADMIN_EMAIL=admin@jouwdomein.be
SEED_ADMIN_PASS=kiesEenSterkWachtwoord
SEED_PARENT_EMAIL=ouder@jouwdomein.be
SEED_PARENT_PASS=kiesEenSterkWachtwoord
SEED_CHILD_NAME=Kind
SEED_CHILD_EMAIL=kind@jouwdomein.be
SEED_CHILD_PIN=1234
